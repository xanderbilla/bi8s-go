# Local shell environment template. Copy to `.envrc` if needed.

# --- Runtime ----------------------------------------------------------------
export APP_ENV="dev"
export PORT=":8080"
export LOG_LEVEL="info"
export LOG_ADD_SOURCE="false"
export BUILD_VERSION="dev"

# --- AWS --------------------------------------------------------------------
export AWS_REGION="us-east-1"
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# --- DynamoDB tables --------------------------------------------------------
export DYNAMODB_MOVIE_TABLE="bi8s-content-table-dev"
export DYNAMODB_PERSON_TABLE="bi8s-person-table-dev"
export DYNAMODB_ATTRIBUTE_TABLE="bi8s-attributes-table-dev"
export DYNAMODB_ATTRIBUTE_NAME_INDEX="name-index"
export DYNAMODB_ENCODER_TABLE="bi8s-video-table-dev"
export DYNAMODB_ENCODER_CONTENT_ID_INDEX="contentId-index"

# --- S3 ---------------------------------------------------------------------
export S3_BUCKET="bi8s-storage-dev"
export STORAGE_BASE_URL="http://localhost:8080"

# --- CORS -------------------------------------------------------------------
export CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8443,https://localhost:8443,http://127.0.0.1:8443,https://127.0.0.1:8443"
export CORS_ALLOW_PRIVATE_NETWORK="true"

# --- Networking / Proxies ---------------------------------------------------
export TRUSTED_PROXIES=""

# --- Rate limiting / Redis --------------------------------------------------
export REDIS_URL="redis://redis:6379/0"
export RATE_LIMIT_BACKEND="memory"
export RATE_LIMIT_REDIS_FAIL_MODE="fail-open"
export RATE_LIMIT_REDIS_TIMEOUT_MS="50"

# --- DynamoDB/Context tuning ------------------------------------------------
export DYNAMODB_MAX_SCAN_PAGES="1000"
export CTX_DB_TIMEOUT_MS="30000"

# --- Encoder ----------------------------------------------------------------
export ENCODER_MAX_CONCURRENT="2"
export ENCODER_FFMPEG_PARALLELISM="0"
export ENCODER_JOB_TIMEOUT_SECONDS="1800"

# --- Filesystem -------------------------------------------------------------
export BI8S_TMP_DIR="/tmp"

# --- OpenTelemetry ----------------------------------------------------------
export OTEL_SERVICE_NAME="bi8s-api"
export OTEL_ENABLED="true"
export OTEL_EXPORTER_OTLP_ENDPOINT="otel-collector:4317"
export OTEL_EXPORTER_OTLP_INSECURE="true"
export OTEL_TRACES_ENABLED="true"
export OTEL_METRICS_ENABLED="true"
export OTEL_TRACES_SAMPLER_ARG="1.0"
export OTEL_METRIC_EXPORT_INTERVAL_SECONDS="15"
export OTEL_SHUTDOWN_TIMEOUT_SECONDS="5"

# --- docker-compose ports ---------------------------------------------------
export API_PORT="8080"
export UI_PORT="8443"
export REDIS_PORT="6379"
export OTEL_GRPC_PORT="4317"
export OTEL_HTTP_PORT="4318"
export OTEL_PROM_PORT="8889"
export PROMETHEUS_PORT="9090"
export TEMPO_HTTP_PORT="3200"
export LOKI_PORT="3100"
export GRAFANA_PORT="4000"
export CADVISOR_PORT="8090"
export NODE_EXPORTER_PORT="9100"

# --- Observability defaults -------------------------------------------------
export PROMETHEUS_RETENTION="72h"
export GRAFANA_ADMIN_USER="admin"
export GRAFANA_ADMIN_PASSWORD="admin"