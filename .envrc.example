# --- Runtime ----------------------------------------------------------------
export APP_ENV="dev"                      # dev | prod
export PORT=":8080"
export LOG_LEVEL="info"                   # debug | info | warn | error
export LOG_ADD_SOURCE="false"

# --- AWS --------------------------------------------------------------------
# Prefer IAM roles in production; these are only for local dev.
export AWS_ACCESS_KEY_ID=AKXXXXXXXXXXXXXX
export AWS_SECRET_ACCESS_KEY=5EXXXXXXXXXXXXXXXXX
export AWS_REGION="us-east-1"

# --- DynamoDB tables --------------------------------------------------------
export DYNAMODB_MOVIE_TABLE="bi8s-dev"
export DYNAMODB_PERSON_TABLE="bi8s-person-dev"
export DYNAMODB_ATTRIBUTE_TABLE="bi8s-attribute-dev"
export DYNAMODB_ENCODER_TABLE="bi8s-video-dev"
export DYNAMODB_ENCODER_CONTENT_ID_INDEX="contentId-index"

# --- S3 ---------------------------------------------------------------------
export S3_BUCKET="your-s3-bucket-name"
export STORAGE_BASE_URL="http://localhost:8080"

# --- CORS -------------------------------------------------------------------
export CORS_ALLOWED_ORIGINS="http://localhost:3000,https://your-domain.com"
export CORS_ALLOW_PRIVATE_NETWORK="true"

# --- Networking / Proxies ---------------------------------------------------
# Comma-separated CIDRs of trusted reverse proxies. When set, the server
# honours X-Forwarded-For for client-IP extraction (rate limiting, logs).
export TRUSTED_PROXIES=""

# --- Encoder ----------------------------------------------------------------
export ENCODER_MAX_CONCURRENT="2"
# Per-job ffmpeg parallelism (0 = let ffmpeg decide based on CPU count).
export ENCODER_FFMPEG_PARALLELISM="0"
# Job context timeout in seconds; default 1800 (30 min).
export ENCODER_JOB_TIMEOUT_SECONDS="1800"

# --- Filesystem -------------------------------------------------------------
# Override the directory used for transient upload/encode temp files.
# Defaults to the OS temp dir (os.TempDir()).
export BI8S_TMP_DIR=""