    {
      "name": "Admin - Encoder",
      "description": "Submit and monitor HLS transcoding jobs. Rate-limited: 5 req/min, burst 5.",
      "item": [
        {
          "name": "POST /v1/a/encoder",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "contentId",
                  "value": "{{movieId}}",
                  "type": "text",
                  "description": "Required. UUID of the existing movie/TV content"
                },
                {
                  "key": "contentType",
                  "value": "MOVIE",
                  "type": "text",
                  "description": "Required. Enum: MOVIE, TV"
                },
                {
                  "key": "video",
                  "type": "file",
                  "src": "",
                  "description": "Required. MP4 video file. In curl use: -F 'video=@file.mp4;type=video/mp4'"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/v1/a/encoder",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "a", "encoder"]
            },
            "description": "Submits an HLS transcoding job. Generates 360p/480p/720p variants. Returns EncoderJob with status=QUEUED. Rate-limited: 5 req/min, burst 5.\n\nIMPORTANT: When using curl, specify the MIME type explicitly:\n  -F 'video=@/path/to/file.mp4;type=video/mp4'"
          }
