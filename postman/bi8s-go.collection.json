    {
      "name": "Consumer / Public",
      "description": "Public-facing endpoints under /v1/c/* that filter by visibility=PUBLIC.",
      "item": [
        {
          "name": "GET /v1/c/content",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/content?type=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "content"],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, tv"
                }
              ]
            },
            "description": "Returns recent public content sorted by creation date. Query: type=all|movie|tv (default: all). Response: ContentPublicList[]"
          }
        },
        {
          "name": "GET /v1/c/content/{contentId}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/content/{{movieId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "content", "{{movieId}}"]
            },
            "description": "Returns public detail for a single content by UUID. Response: ContentPublicDetail (excludes stats, audit, visibility)."
          }
        },
        {
          "name": "GET /v1/c/people/{peopleId}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/people/{{personId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "people", "{{personId}}"]
            },
            "description": "Returns public profile for a person by numeric ID. Response: PersonPublicDetail (excludes stats, audit)."
          }
        },
        {
          "name": "GET /v1/c/people/{peopleId}/content",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/people/{{personId}}/content?type=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "people", "{{personId}}", "content"],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, tv"
                }
              ]
            },
            "description": "Returns public content where the person appears in the cast. Response: { id, title, backdropPath }[]"
          }
        },
        {
          "name": "GET /v1/c/banner",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/banner?type=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "banner"],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, tv"
                }
              ]
            },
            "description": "Returns random banner content. Response: BannerContent { id, backdropPath, title, overview, contentRating, assets }"
          }
        },
        {
          "name": "GET /v1/c/discover",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/discover?type=latest&content=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "discover"],
              "query": [
                {
                  "key": "type",
                  "value": "latest",
                  "description": "Discovery type: latest (default)"
                },
                {
                  "key": "content",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, tv"
                }
              ]
            },
            "description": "Discovery feed. Query: type=latest (default), content=all|movie|tv (default: all). Response: ContentPublicList[]"
          }
        },
        {
          "name": "GET /v1/c/attributes/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/attributes/{{attributeId}}?content=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "attributes", "{{attributeId}}"],
              "query": [
                {
                  "key": "content",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, tv"
                }
              ]
            },
            "description": "Returns content filtered by attribute ID (genre, mood, tag, etc.). Query: content=all|movie|tv. Response: { id, title, backdropPath }[]"
          }
        },
        {
          "name": "GET /v1/c/play/{contentType}/{contentId}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/play/{{contentType}}/{{movieId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "play", "{{contentType}}", "{{movieId}}"]
            },
            "description": "Returns HLS playback info. Path params: contentType=MOVIE|TV (validated), contentId=UUID (validated). Response: PlaybackInfo { contentId, contentType, info { title, overview, casts }, playback { durationSec, streaming, video, audio, subtitles, preview, thumbnails, sprite } }"
          }
        }
      ]
