            "url": {
              "raw": "{{baseUrl}}/v1/movies",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "movies"]
            },
            "description": "Creates a movie with all fields via multipart/form-data. Uploads poster, cover, cast images, and studio images to S3. Movie ID is auto-generated. Entity IDs (genres, tags, etc.) are auto-generated if not provided. Date format: YYYY-MM-DD (stored as YYYY-MM-DD, validated between 2006-01-01 and today)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 409', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  const createdId = body?.data?.id;",
                  "  pm.test('Created movie contains generated id', function () {",
                  "    pm.expect(createdId).to.be.a('string').and.not.empty;",
                  "  });",
                  "  if (createdId) {",
                  "    pm.collectionVariables.set('movieId', createdId);",
                  "  }",
                  "}",
                  "",
                  "pm.test('Response contains all expected fields', function () {",
                  "  if (pm.response.code === 201) {",
                  "    const data = pm.response.json().data;",
                  "    pm.expect(data).to.have.property('title');",
                  "    pm.expect(data).to.have.property('overview');",
                  "    pm.expect(data).to.have.property('release_date');",
                  "    pm.expect(data).to.have.property('content_rating');",
                  "    pm.expect(data).to.have.property('content_type');",
                  "    pm.expect(data).to.have.property('studios');",
                  "    pm.expect(data).to.have.property('casts');",
                  "    pm.expect(data).to.have.property('audit');",
                  "  }",
                  "});"
                ]
              }
