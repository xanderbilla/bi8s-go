              "path": ["v1", "openapi.yaml"]
            },
            "description": "Returns the raw OpenAPI 3.0 spec as YAML."
          }
        },
        {
          "name": "GET /v1/docs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/docs",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "docs"]
            },
            "description": "Serves the Swagger UI for the OpenAPI spec."
          }
        },
        {
          "name": "GET /v1/debug/vars",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/debug/vars",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "debug", "vars"]
