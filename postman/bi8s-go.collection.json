{
  "info": {
    "_postman_id": "f4b0870c-a801-4b5b-a312-38a5d4af8d77",
    "name": "bi8s-go API",
    "description": "Postman collection for all currently available bi8s-go routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /v1/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/health",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "health"]
            },
            "description": "Checks if the API is running and returns environment version details."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Store request start time for optional debugging in Postman runner.",
                  "pm.variables.set('requestStartTime', Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains expected envelope fields', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('status');",
                  "  pm.expect(body).to.have.property('message');",
                  "  pm.expect(body).to.have.property('data');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "GET /v1/movies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/movies",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "movies"]
            },
            "description": "Returns all movies from DynamoDB."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response envelope exists', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('status');",
                  "  pm.expect(body).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /v1/movies/{movieId}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/movies/{{movieId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "movies", "{{movieId}}"]
            },
            "description": "Returns a single movie by ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 404', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /v1/movies",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Interstellar",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "A team travels through a wormhole to ensure humanity's survival.",
                  "type": "text"
                },
                {
                  "key": "performer",
                  "value": "Matthew McConaughey",
                  "type": "text"
                },
                {
                  "key": "year",
                  "value": "2014",
                  "type": "text"
                },
                {
                  "key": "poster",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "cover",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/v1/movies",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "movies"]
            },
            "description": "Creates a movie via multipart/form-data and uploads poster and cover to S3. If ID is omitted, server generates it. On 201, generated ID is saved into {{movieId}} for subsequent requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201 or 409', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  const createdId = body?.data?.id;",
                  "  pm.test('Created movie contains generated id', function () {",
                  "    pm.expect(createdId).to.be.a('string').and.not.empty;",
                  "  });",
                  "  if (createdId) {",
                  "    pm.collectionVariables.set('movieId', createdId);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /v1/movies/{movieId}",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/movies/{{movieId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "movies", "{{movieId}}"]
            },
            "description": "Deletes a movie by ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 404', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "movieId",
      "value": "movie-1"
    }
  ]
}
