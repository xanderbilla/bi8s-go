    {
      "name": "System",
      "description": "Health, liveness, readiness, and documentation endpoints.",
      "item": [
        {
          "name": "GET /v1/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/health",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "health"]
            },
            "description": "Full health check. Runs concurrent DynamoDB, S3, ffmpeg, ffprobe checks (2s timeout). Returns 200 with checks map (up/down), or 503 if any dep is down."
          }
        },
        {
          "name": "GET /v1/livez",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/livez",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "livez"]
            },
            "description": "Liveness probe. Always returns 200 if the process is running."
          }
        },
        {
          "name": "GET /v1/readyz",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/readyz",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "readyz"]
            },
            "description": "Readiness probe. Returns 503 NOT_READY until bootstrap completes, then runs health checks."
          }
        },
        {
          "name": "GET /v1/openapi.yaml",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/openapi.yaml",
