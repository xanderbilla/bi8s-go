            "description": "Checks if the API is running and returns environment version details."
          }
        }
      ]
    },
    {
      "name": "Customer/Public Endpoints",
      "description": "Public-facing endpoints under /v1/c/* that filter by visibility=PUBLIC and status=RELEASED or IN_PRODUCTION.",
      "item": [
        {
          "name": "GET /v1/c/content",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/content?type=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "content"],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, or tv"
                }
              ]
            },
            "description": "Returns recent content sorted by creation date. Query params: type=all|movie|tv (default: all)"
          }
        },
        {
          "name": "GET /v1/c/content/{contentId}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/content/{{movieId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "content", "{{movieId}}"]
            },
            "description": "Returns a single content by ID. Excludes stats, audit, and visibility fields."
          }
        },
        {
          "name": "GET /v1/c/people/{peopleId}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/people/{{personId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "people", "{{personId}}"]
            },
            "description": "Returns a single person by ID with public fields."
          }
        },
        {
          "name": "GET /v1/c/people/{peopleId}/content",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/people/{{personId}}/content?type=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "people", "{{personId}}", "content"],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, or tv"
                }
              ]
            },
            "description": "Returns all content where the person is in the cast. Query params: type=all|movie|tv (default: all). Returns: id, title, backdropPath"
          }
        },
        {
          "name": "GET /v1/c/banner",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/banner?type=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "banner"],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, or tv"
                }
              ]
            },
            "description": "Returns random banner content. Query params: type=all|movie|tv (default: all). Response: id, backdropPath, title, overview, contentRating"
          }
        },
        {
          "name": "GET /v1/c/discover",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/discover?type=latest&content=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "discover"],
              "query": [
                {
                  "key": "type",
                  "value": "latest",
                  "description": "Discovery type: latest (default), popular (TODO), trending (TODO)"
                },
                {
                  "key": "content",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, or tv"
                }
              ]
            },
            "description": "Discovers content. Query params: type=latest|popular|trending (default: latest), content=all|movie|tv (default: all)"
          }
        },
        {
          "name": "GET /v1/c/attributes/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/c/attributes/{{attributeId}}?content=all",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "c", "attributes", "{{attributeId}}"],
              "query": [
                {
                  "key": "content",
                  "value": "all",
                  "description": "Content type filter: all (default), movie, or tv"
                }
              ]
            },
            "description": "Returns content by attribute ID. Query params: content=all|movie|tv (default: all). Returns: id, title, backdropPath"
          }
        }
      ]
    },
