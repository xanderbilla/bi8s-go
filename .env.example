# ────────────────────────────────────────────────────────────────────────────
# bi8s-go — local development environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ────────────────────────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=dev
PORT=:8080
LOG_LEVEL=info
BUILD_VERSION=dev

# ── HTTP / CORS ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8443,http://127.0.0.1:8443
CORS_ALLOW_PRIVATE_NETWORK=true

# ── AWS credentials & region ────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── DynamoDB tables ─────────────────────────────────────────────────────────
DYNAMODB_MOVIE_TABLE=bi8s-content-table-dev
DYNAMODB_PERSON_TABLE=bi8s-person-table-dev
DYNAMODB_ATTRIBUTE_TABLE=bi8s-attributes-table-dev
DYNAMODB_ENCODER_TABLE=bi8s-video-table-dev
DYNAMODB_ENCODER_CONTENT_ID_INDEX=contentId-index

# ── S3 ──────────────────────────────────────────────────────────────────────
S3_BUCKET=bi8s-storage-dev

# ── Observability S3 backends (provisioned by Terraform) ───────────────────
# Bucket names match infra/tofu/envs/dev/main.tf locals.
LOKI_BUCKET=bi8s-loki-chunks-dev
TEMPO_BUCKET=bi8s-tempo-traces-dev

# ── OpenTelemetry (Go app -> OTel Collector ONLY) ──────────────────────────
OTEL_SERVICE_NAME=bi8s-api
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_METRIC_EXPORT_INTERVAL_SECONDS=15
OTEL_SHUTDOWN_TIMEOUT_SECONDS=5

# ── Host port mappings (override only if conflicts) ────────────────────────
API_PORT=8080
UI_PORT=8443
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROM_PORT=8889
PROMETHEUS_PORT=9090
TEMPO_HTTP_PORT=3200
LOKI_PORT=3100
GRAFANA_PORT=4000
CADVISOR_PORT=8090
NODE_EXPORTER_PORT=9100

# ── Prometheus ─────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=72h

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── UI build (optional — only needed if you bring up the `ui` profile) ─────
UI_BUILD_CONTEXT=./ui
UI_ENV_FILE=.env.local
UI_NODE_ENV=development
