# bi8s-go — local development environment template
# Copy to `.env` and fill in your real AWS credentials. NEVER commit `.env`.

# Application
APP_ENV=dev
PORT=:8080
LOG_LEVEL=info
LOG_ADD_SOURCE=false
BUILD_VERSION=dev

# HTTP / CORS
# Comma-separated list of origins the browser is allowed to call the API from.
# Add your Tailscale IP (e.g. https://100.98.33.20) for device-to-device access.
# Add your Amplify/Vercel/Netlify preview URL for frontend-to-API calls.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8443,http://127.0.0.1:8443,https://localhost,https://127.0.0.1,https://100.98.33.20,https://dev.d3uphs6spds7z1.amplifyapp.com
CORS_ALLOW_PRIVATE_NETWORK=true
# Per-request body caps (bytes). JSON is small; multipart uploads (videos/images)
# need to be much larger. Defaults: 1 MiB JSON, 1 GiB multipart.
HTTP_MAX_JSON_BYTES=1048576
HTTP_MAX_MULTIPART_BYTES=1073741824

# AWS credentials & region - Required for DynamoDB and S3 access
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# DynamoDB tables
DYNAMODB_CONTENT_TABLE=bi8s-content-table-dev
DYNAMODB_PERSON_TABLE=bi8s-person-table-dev
DYNAMODB_ATTRIBUTE_TABLE=bi8s-attributes-table-dev
DYNAMODB_ATTRIBUTE_NAME_INDEX=name-index
DYNAMODB_ENCODER_TABLE=bi8s-video-table-dev
DYNAMODB_ENCODER_CONTENT_ID_INDEX=contentId-index
DYNAMODB_CONTENT_CAST_TABLE=bi8s-content-cast-table-dev
DYNAMODB_CONTENT_ATTRIBUTE_TABLE=bi8s-content-attribute-table-dev
DYNAMODB_CONTENT_VISIBILITY_CREATED_AT_INDEX=visibility-createdAt-index
DYNAMODB_CONTENT_VISIBILITY_RELEASE_DATE_INDEX=visibility-releaseDate-index
DYNAMODB_MAX_SCAN_PAGES=1000

# Context/Database timeouts
CTX_DB_TIMEOUT_MS=30000

# S3 bucket - used by app uploads AND observability backends (Loki/Tempo)
S3_BUCKET=bi8s-storage-dev
STORAGE_BASE_URL=http://localhost:8080

# Networking / Proxies - comma-separated list of trusted reverse proxy CIDRs
TRUSTED_PROXIES=

# Redis - shared rate-limit backend (required when RATE_LIMIT_BACKEND=redis)
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://redis:6379/0

# Rate limiting
# Backend: "memory" (per-instance, dev only) or "redis" (multi-replica safe)
RATE_LIMIT_BACKEND=memory
# Behavior when Redis is unreachable: "fail-open" (allow) or "fail-closed" (deny)
RATE_LIMIT_REDIS_FAIL_MODE=fail-open
RATE_LIMIT_REDIS_TIMEOUT_MS=50

# Search (OpenSearch)
SEARCH_ENABLED=true
SEARCH_PROVIDER=opensearch
SEARCH_ENDPOINT=http://opensearch:9200
SEARCH_USERNAME=
SEARCH_PASSWORD=
SEARCH_CONTENT_INDEX=bi8s-content-search
SEARCH_PEOPLE_INDEX=bi8s-people-search
SEARCH_REQUEST_TIMEOUT_MS=3000
SEARCH_AUTO_REINDEX_TIMEOUT_SECONDS=300

# Playback
PLAYBACK_URL_TTL_MINUTES=20

# Encoder
ENCODER_MAX_CONCURRENT=2
ENCODER_FFMPEG_PARALLELISM=0
ENCODER_JOB_TIMEOUT_SECONDS=1800

# Filesystem
BI8S_TMP_DIR=/tmp

# OpenTelemetry - Go app sends traces and metrics to OTel Collector
OTEL_SERVICE_NAME=bi8s-api
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_METRIC_EXPORT_INTERVAL_SECONDS=15
OTEL_SHUTDOWN_TIMEOUT_SECONDS=5

# Host port mappings - override only if you have port conflicts
API_PORT=8080
REDIS_PORT=6379
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROM_PORT=8889
PROMETHEUS_PORT=9090
TEMPO_HTTP_PORT=3200
LOKI_PORT=3100
GRAFANA_PORT=4000
CADVISOR_PORT=8090
NODE_EXPORTER_PORT=9100
OPENSEARCH_PORT=9200
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_TUNNEL_PORT=8081

# Prometheus
PROMETHEUS_RETENTION=72h

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Cloudflare Tunnel (required when using the `https` profile with cloudflared)
# Generate a token at: https://one.dash.cloudflare.com/ → Access → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=


